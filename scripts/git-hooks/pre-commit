#!/bin/bash
# Pre-commit helper: Scope-aware documentation enforcement
#
# Ensures that source code changes include documentation updates
# within the SAME scope (nearest ancestor directory with README.md).
#
# Uses shared configuration and logic from:
#   - doc-enforcement.conf  (patterns, thresholds)
#   - doc-enforcement-lib.sh (scope resolution, validation)
#
# This script is invoked by `.pre-commit-config.yaml`.
# To bypass in emergencies: git commit --no-verify

set -e

# ANSI color codes
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# ── Resolve script directory and source shared code ──────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ ! -f "${SCRIPT_DIR}/doc-enforcement.conf" ]] || \
   [[ ! -f "${SCRIPT_DIR}/doc-enforcement-lib.sh" ]]; then
  echo -e "${YELLOW}Warning: doc-enforcement config/lib not found. Skipping.${NC}"
  exit 0
fi

# shellcheck source=doc-enforcement.conf
source "${SCRIPT_DIR}/doc-enforcement.conf"
# shellcheck source=doc-enforcement-lib.sh
source "${SCRIPT_DIR}/doc-enforcement-lib.sh"

# ── Get staged files ─────────────────────────────────────────────
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [[ -z "$STAGED_FILES" ]]; then
  exit 0
fi

# ── Run scope-aware validation ───────────────────────────────────
if validate_scoped_docs "staged" <<< "$STAGED_FILES"; then
  # ── PASSED ───────────────────────────────────────────────────
  if [[ "$TOTAL_SOURCE_COUNT" -gt 0 ]]; then
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}✓ Documentation Enforcement: PASSED${NC}"
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}✓${NC} Source files: ${TOTAL_SOURCE_COUNT}"
    echo -e "${GREEN}✓${NC} Documentation files: ${TOTAL_DOC_COUNT}"
    if [[ "$TOTAL_TEST_COUNT" -gt 0 ]]; then
      echo -e "${GREEN}✓${NC} Test files (exempt): ${TOTAL_TEST_COUNT}"
    fi
    echo ""
  fi
  exit 0
fi

# ── FAILED ─────────────────────────────────────────────────────
if [[ "$DOC_ENFORCEMENT_MODE" == "warn" ]]; then
  echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${YELLOW}⚠ Documentation Enforcement: WARNING (advisory mode)${NC}"
  echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
else
  echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${RED}✗ COMMIT REJECTED: Documentation Update Required${NC}"
  echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
fi

echo ""
echo -e "${YELLOW}The following scope(s) have source code changes but no documentation update:${NC}"
echo ""

for scope in "${UNSATISFIED_SCOPES[@]}"; do
  echo -e "${BLUE}Scope: ${NC}${scope}"
  echo -e "${BLUE}  Source files:${NC}"
  while IFS= read -r sf; do
    [[ -z "$sf" ]] && continue
    echo -e "    ${YELLOW}•${NC} ${sf}"
  done <<< "${SCOPE_SOURCE_FILES[$scope]}"
  echo -e "${BLUE}  Required:${NC} Update or create a .md file within ${scope}"
  echo ""
done

echo -e "${BLUE}Repository Policy:${NC}"
echo -e "  • Code changes MUST include documentation in the SAME scope"
echo -e "  • Scope = nearest ancestor directory containing README.md"
echo -e "  • Test files are exempt from this requirement"
echo ""
echo -e "${BLUE}Emergency bypass:${NC}"
echo -e "  git commit --no-verify  ${YELLOW}(Use only when absolutely necessary)${NC}"
echo ""

if [[ "$DOC_ENFORCEMENT_MODE" == "warn" ]]; then
  exit 0
else
  exit 1
fi
